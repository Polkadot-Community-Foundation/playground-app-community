# Target network for the whole app — Asset Hub, Bulletin, and the People chain
# move together. Supplied at build time (Vite inlines it). Unset = "paseo"
# (local dev, tsx scripts, current CI). Set to "summit" to build against the
# summit network. Any other value fails the build loudly. Supported: paseo, summit.
# VITE_ENVIRONMENT=paseo

# Sentry DSN. Supplied at build time — CI reads it from the SENTRY_DSN GitHub
# Actions secret and passes it as VITE_SENTRY_DSN. Unset (the default) disables
# Sentry, so local dev/builds run without it. Set it here to enable Sentry
# locally or to point at a different project. The DSN is public-safe (send-only).
# VITE_SENTRY_DSN=

# Point the frontend at a different cdm package for the registry contract.
# Production default = @w3s/playground-registry. When iterating on a new
# contract version that has only been deployed to @staging, set this to
# @staging/playground-registry so the runtime resolves to the new ABI.
# Leave commented in production deploys.
# VITE_PLAYGROUND_REGISTRY_PACKAGE=@staging/playground-registry
